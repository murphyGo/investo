# OS
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
*.swp
*.swo

# Python
__pycache__/
*.py[cod]
*.pyo
.venv/
venv/
env/
*.egg-info/
dist/
build/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Go
vendor/
*.test
*.out

# Node
node_modules/
npm-debug.log*
yarn-error.log*

# Secrets & credentials
.env
.env.*
!.env.example
*.pem
*.key
secrets/
credentials/

# Model artifacts (ML weights only — anchored to repo root to avoid src/investo/models/)
*.onnx
*.pkl
*.pt
*.bin
*.h5
/models/

# Data (anchored to repo root to avoid src/investo/data/ if introduced later)
/data/
*.csv
*.parquet
*.jsonl
!aidlc-docs/**/*.jsonl
# u31 source health, u42 quality history, u44 forecast log all
# persist append-only JSONL meta under archive/_meta/. These are
# part of the published archive (read by site rendering + KPI
# pages), not raw data dumps.
!archive/**/*.jsonl
# Test fixtures recorded under R10 (live API responses captured
# byte-equal). Whitelisted past the global *.csv / *.parquet rules
# so adapter recordings (e.g. stooq-price CSV) commit cleanly.
!tests/**/*.csv
!tests/**/*.parquet

# Logs
logs/
*.log

# Google Docs
*.gdoc
*.gsheet
*.gslides
*.gdraw

# Temp
tmp/
temp/
.tmp/

# Obsidian
.obsidian/

# MkDocs build output (u6 — generated by `mkdocs build`; published as
# the GHA Pages artifact, never checked in).
/site/